# Copy this file to .env and fill in your values
# Never commit .env to version control

DB_HOST=localhost
DB_PORT=5432
DB_NAME=inventory_db
DB_USER=postgres
DB_PASSWORD=your_password_here

ALERT_RECIPIENTS=planner@yourcompany.com,ops@yourcompany.com
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_smtp_user
SMTP_PASSWORD=your_smtp_password

# Power BI Service Principal (optional - for auto-refresh)
PBI_TENANT_ID=
PBI_CLIENT_ID=
PBI_CLIENT_SECRET=
PBI_WORKSPACE_ID=
PBI_DATASET_ID=
